{
  "name": "notes-api",
  "version": "1.0.0",
  "description": "A notes API for learning production backend patterns",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development nodemon --watch src --ext ts --exec 'tsx src/index.ts'",
    "build": "tsc",
    "start": "NODE_ENV=production tsx src/index.ts",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test:01": "node tests/lesson-01.js",
    "test:02": "node tests/lesson-02.js",
    "test:03": "node tests/lesson-03.js",
    "test:04": "node tests/lesson-04.js",
    "test:06": "node tests/lesson-06.js"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.0",
    "morgan": "^1.11.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.10",
    "@types/node": "^22.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "nodemon": "^3.1.4",
    "prettier": "^3.8.3",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.59.3"
  }
}
